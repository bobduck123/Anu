{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anu.eco/contracts/health-readiness.contract.schema.json",
  "title": "ANU Runtime Health and Readiness Contract",
  "type": "object",
  "required": [
    "status",
    "service",
    "component",
    "contract_version",
    "timestamp",
    "dependencies"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "not_ready"]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "component": {
      "type": "string",
      "enum": ["frontend", "core", "impact"]
    },
    "protocol": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "contract_version": {
      "type": "string",
      "const": "m0.2026-04-01"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ready": {
      "type": "boolean"
    },
    "dependencies": {
      "type": "object",
      "required": ["database", "redis", "stripe", "postgis"],
      "properties": {
        "database": {
          "$ref": "#/$defs/dependencyStatus"
        },
        "redis": {
          "$ref": "#/$defs/dependencyStatus"
        },
        "stripe": {
          "$ref": "#/$defs/dependencyStatus"
        },
        "postgis": {
          "$ref": "#/$defs/dependencyStatus"
        }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/checkStatus"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "dependencyStatus": {
      "type": "string",
      "enum": ["ok", "error", "placeholder", "skipped"]
    },
    "checkStatus": {
      "type": "string",
      "enum": ["ok", "error", "skipped"]
    }
  }
}
