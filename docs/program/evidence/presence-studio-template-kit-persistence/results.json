{
  "date": "2026-05-29",
  "persistenceContract": {
    "id": "presence-editable-config-compat-v1",
    "decision": "Store TemplateKit-created Studio Room drafts in an owner-private PresenceNode plus draft PresenceEditableConfig.content_config.studio_room_draft.",
    "migrationRequired": false,
    "reason": "The existing editor draft table already supports owner-scoped JSON payloads, draft/published status separation, URL sanitization, and public redaction."
  },
  "endpoint": {
    "method": "POST",
    "path": "/api/presence/owner/studio-rooms/from-template-kit",
    "auth": "alpha_jwt_required owner session",
    "rejectsCandidateKits": true,
    "rejectsUnsafeUrls": true,
    "rejectsBroadContactFields": true
  },
  "editorShell": {
    "path": "/studio/[id]/studio-room",
    "ownerGate": "useOwnerNode + StudioNodeGate",
    "canvas": "StudioRoomCanvas with toPublicRoomPayload",
    "publishActionPresent": false
  },
  "ownerCreatableKits": [
    "gallery-artist",
    "cultural-community-artist",
    "material-tradie-proof-card",
    "healing-practitioner",
    "consultant-contractor"
  ],
  "candidateKits": [
    "underground-dj-portal"
  ],
  "draftPublishSeparation": {
    "createdStatus": "draft",
    "createdVisibility": "private",
    "createdPublicStatus": "draft",
    "publishedConfigCreated": false,
    "publishedAt": null,
    "basePublishedVersion": 0,
    "publicRouteVisible": false
  },
  "payloadHygiene": {
    "studioRoomDraftPublicRedacted": true,
    "sourceCandidateContentScrubbed": true,
    "privateContactMappingAdded": false,
    "editorOnlyFieldsExposed": false,
    "unsafeUrlBlocked": true
  },
  "publicRouteIsolation": {
    "publicRouteImportsStudioRoomCanvas": false,
    "publicRouteImportsTemplateKitStarter": false,
    "publicRouteImportsTemplateDrafts": false,
    "publicRouteImportsStudioRoomOwnerEditorShell": false,
    "publicRouteImportsPersistenceClient": false
  },
  "runtimeAiScan": {
    "openai": false,
    "anthropic": false,
    "langchain": false,
    "aiSdk": false,
    "chatbot": false,
    "runtimeModelInference": false
  },
