    "display_name": "Christina Kerkvliet Goddard",
    "headline": "Australian artist working across memory, colour, and lived landscape",
    "hero_title": "Colour as Memory",
    "hero_subtitle": "selected watercolour works",
    "about": {
      "biography": "Born in Victoria and raised in South Australia, Christina grew up around the active art scene of the 1960s and 70s.",
      "artist_statement": "Memory Colours revisits and haunts its sites of episode as a way to present how colour can generate memory.",
      "process_notes": "Layered watercolour, line, atmosphere, landscape, and remembered encounter.",
      "studio_fragments": [
        "memory colours",
        "life-cycles",
        "nature episodes",
        "independent inquiry"
      ],
      "timeline": [
        { "when": "Early years", "what": "Drawing, craft instincts, and immersion in South Australian visual culture." },
        { "when": "Formal study", "what": "Certificate of Art, followed by BA of Visual Arts." },
        { "when": "Practice period", "what": "Community contribution, commissions, and experimental exhibitions." },
        { "when": "2009", "what": "Accepted into RMIT's Master of Fine Art program." },
        { "when": "2011", "what": "Art Scene Today Spring competition - 3rd Place Winner." }
      ],
      "strands": [
        { "title": "Memory colours", "body": "Colour as a trigger for recollection, emotional episode, and narrative permeability." },
        { "title": "Life-cycles", "body": "Nest, branch, path, and seasonal shifts as recurring forms of generational relation." },
        { "title": "Outsider position", "body": "A practice that values independent inquiry and cross-disciplinary material language." },
        { "title": "Nature episodes", "body": "Brief encounters in the everyday natural environment translated into layered mark-fields." }
