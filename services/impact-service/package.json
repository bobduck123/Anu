{
  "name": "impact-service",
  "version": "1.0.0",
  "description": "Manara impact service - memberships, pools, credits, and memetic liquidity",
  "main": "src/server.ts",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:staging": "ts-node prisma/seed.staging.ts",
    "falak:db:up": "node scripts/falak-local/docker-compose.mjs up",
    "falak:db:down": "node scripts/falak-local/docker-compose.mjs down",
    "falak:db:logs": "node scripts/falak-local/docker-compose.mjs logs",
    "falak:db:ps": "node scripts/falak-local/docker-compose.mjs ps",
    "falak:prisma:generate:local": "node scripts/falak-local/prisma-generate.mjs",
    "falak:migrate:local": "node scripts/falak-local/migrate.mjs",
    "falak:seed:local": "node scripts/falak-local/seed.mjs",
    "falak:test:integration:local": "node scripts/falak-local/integration-tests.mjs",
    "falak:verify:local": "node scripts/falak-local/verify.mjs",
    "falak:prisma:generate:staging": "node scripts/falak-staging/prisma-generate.mjs",
    "falak:migrate:staging": "node scripts/falak-staging/migrate-deploy.mjs",
    "falak:seed:staging": "node scripts/falak-staging/seed.mjs",
    "falak:target:staging": "node scripts/falak-staging/print-target.mjs",
    "falak:readiness:staging": "node scripts/falak-staging/readiness.mjs",
    "falak:smoke:staging": "node scripts/falak-staging/smoke.mjs",
    "falak:verify:staging": "node scripts/falak-staging/verify.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^3.0.0",
    "pino": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "jest": "^29.0.0",
    "prisma": "^5.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
