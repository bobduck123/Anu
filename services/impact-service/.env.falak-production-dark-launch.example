# Overlay these Falak settings onto the existing production environment.
# Do not use this file as a full production env replacement.
# Do not run prisma migrate deploy against an existing production DB unless
# a separate reconciliation or replacement plan has been approved.

FALAK_ROUTE_GUARD_MODE=disabled
FALAK_MAP_ROUTE_GUARD_MODE=disabled
FALAK_ALLOWED_TENANT_SLUGS=
FALAK_ALLOWED_ACTOR_EXTERNAL_AUTH_IDS=
FALAK_TRUST_X_ACTOR_ID=false
FALAK_REQUIRE_VERIFIED_ACTOR=true
