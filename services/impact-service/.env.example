PORT=5003
NODE_ENV=development

# =============================================================================
# DATABASE CONFIGURATION
# Connected to Supabase with access to PUBLIC and FALAK schemas
# This service connects to schema 002_impact_schema and 003_falak_schema
# =============================================================================
DATABASE_URL=postgresql://postgres:your-password@your-host:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres:your-password@your-host:5432/postgres?schema=public
TEST_DATABASE_URL=postgresql://postgres:your-password@localhost:5432/postgres?schema=public

# =============================================================================
# AUTHENTICATION & JWT
# Must match Flora-Fauna backend's JWT_SECRET_KEY for token validation
# =============================================================================
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars

# =============================================================================
# STRIPE PAYMENT PROCESSING
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# CORS - Cross-Origin Resource Sharing
# Frontend URLs that can access this service
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_ORIGIN_SUFFIXES=.vercel.app

# =============================================================================
# SCHEDULED JOBS & BACKGROUND TASKS
# Disable for serverless deployments (Vercel, Lambda, etc.)
# =============================================================================
DISABLE_SCHEDULED_JOBS=true

# =============================================================================
# FALAK PROTOCOL SERVICE
# Enables multi-tenant Falak protocol features (schemas, tenants, actors)
# =============================================================================
FALAK_ENABLED=true
FALAK_DEFAULT_TENANT_SLUG=anu
