PORT=5003
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/impact_service
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/impact_test

# JWT (must match Flask's JWT_SECRET_KEY)
JWT_SECRET_KEY=your_jwt_secret_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGIN_SUFFIXES=.vercel.app

# Serverless deployments should keep background jobs disabled.
DISABLE_SCHEDULED_JOBS=true
