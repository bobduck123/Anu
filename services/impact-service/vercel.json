{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "fluid": true,
  "regions": ["syd1", "sin1"],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/falak.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/migrations.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/v1/falak/health",
      "dest": "api/falak.ts"
    },
    {
      "src": "/v1/falak/readiness",
      "dest": "api/falak.ts"
    },
    {
      "src": "/v1/falak/(.*)",
      "dest": "api/falak.ts"
    },
    {
      "src": "/v1/education/maps",
      "dest": "api/falak.ts"
    },
    {
      "src": "/v1/education/maps/(.*)",
      "dest": "api/falak.ts"
    },
    {
      "src": "/docs",
      "dest": "api/falak.ts"
    },
    {
      "src": "/docs/(.*)",
      "dest": "api/falak.ts"
    },
    {
      "src": "/openapi.json",
      "dest": "api/falak.ts"
    },
    {
      "src": "/api/migrations",
      "dest": "api/migrations.ts"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
