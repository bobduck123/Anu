# Hosted staging verification environment for the Falak rollout package.
# Copy to `.env.falak-staging` for operator-driven staging commands.
# This file is not the same as the hosted Vercel runtime env.
# Fill it with the real deployed staging URL and the real fresh staging DB URLs
# before running the staging verification scripts.

NODE_ENV=production
LOG_LEVEL=info

# Hosted staging app URL. This must not be the current live alpha URL.
STAGING_BASE_URL=https://anu-falak-staging.example.com
# Public frontend host used by proxy verification, not the direct impact-service origin.
PRODUCTION_BASE_URL=https://maanara.vercel.app
# Optional frontend staging host for proxy verification when a staged frontend exists.
STAGING_FRONTEND_BASE_URL=
STAGING_PROXY_MAP_ROUTE_MODE=falak
STAGING_MANARA_FEED_MODE=placeholder
STAGING_FALAK_TENANT_ID=
FALAK_STAGING_HOST_FRAGMENT=staging
FALAK_STAGING_ENVIRONMENT_NAME=anu-falak-staging

# Safety switch for any mutating staging command or seed.
# Leave this false until the target URL and DB have been validated as fresh
# staging-only infrastructure. Set it to true only while running
# falak:migrate:staging and falak:seed:staging, then switch it back to false.
FALAK_STAGING_ALLOW_MUTATIONS=false

# Fresh dedicated staging Supabase/Postgres/PostGIS database only.
# Runtime should use the transaction pooler. Prisma CLI should use the direct DB host.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
FALAK_STAGING_DATABASE_EXPECTED_NAME=anu_falak_staging

# Required service secret.
JWT_SECRET_KEY=replace-with-a-staging-only-secret

# Falak route gating for hosted staging verification.
FALAK_ROUTE_GUARD_MODE=tenant_allowlist
FALAK_MAP_ROUTE_GUARD_MODE=tenant_allowlist
FALAK_ALLOWED_TENANT_SLUGS=anu-beta
FALAK_ALLOWED_ACTOR_EXTERNAL_AUTH_IDS=anu-admin,anu-governor
FALAK_TRUST_X_ACTOR_ID=false
FALAK_REQUIRE_VERIFIED_ACTOR=true

# Optional infrastructure. Keep empty unless staging needs it.
REDIS_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
REQUIRE_STRIPE_INFRA=false
BETA_ALLOW_PLACEHOLDER_INFRA=false
DISABLE_SCHEDULED_JOBS=true

# Seed discovery for the staging smoke tests.
FALAK_SMOKE_TENANT_SLUG=anu-beta
FALAK_SMOKE_ADMIN_EXTERNAL_AUTH_ID=anu-admin
FALAK_SMOKE_GOVERNOR_EXTERNAL_AUTH_ID=anu-governor
FALAK_SMOKE_VENUE_SLUG=anu-school-of-music
FALAK_SMOKE_COMMUNITY_SLUG=ngunnawal-arts-circle
FALAK_SMOKE_CAMPAIGN_SLUG=first-nations-stage-fund
FALAK_SMOKE_POOL_SLUG=weaving-futures-pool
FALAK_SMOKE_RESTRICTED_STORY_SLUG=songlines-of-lake-burley

# Verification contract toggles for the current rollout stage.
PRODUCTION_PROXY_MAP_ROUTE_MODE=legacy
PRODUCTION_MANARA_FEED_MODE=placeholder
PRODUCTION_FALAK_TENANT_ID=
