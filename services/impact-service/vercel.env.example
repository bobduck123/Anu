# Apply these in the Production Vercel project for `services/impact-service`.
# Do not use this file for Preview/Staging. Use `vercel.staging.env.example` there.
# Keep Falak dark-launched in Production unless a later change is explicitly approved.
# Current frontend origin: https://maanara.vercel.app

NODE_ENV=production
LOG_LEVEL=info
BETA_ALLOW_PLACEHOLDER_INFRA=true

DATABASE_URL=TODO_REQUIRED_POSTGRES_DATABASE_URL
JWT_SECRET_KEY=replace-with-the-same-jwt-secret-used-by-the-core-api

STRIPE_SECRET_KEY=TODO_REQUIRED_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=TODO_REQUIRED_STRIPE_WEBHOOK_SECRET
STRIPE_PUBLISHABLE_KEY=TODO_REQUIRED_STRIPE_PUBLISHABLE_KEY

CORS_ORIGINS=https://maanara.vercel.app,https://anu-front-end.vercel.app
CORS_ALLOWED_ORIGIN_SUFFIXES=.vercel.app
DISABLE_SCHEDULED_JOBS=true

# Falak production dark-launch defaults.
FALAK_ROUTE_GUARD_MODE=disabled
FALAK_MAP_ROUTE_GUARD_MODE=disabled
FALAK_ALLOWED_TENANT_SLUGS=
FALAK_ALLOWED_ACTOR_EXTERNAL_AUTH_IDS=
FALAK_TRUST_X_ACTOR_ID=false
FALAK_REQUIRE_VERIFIED_ACTOR=true
