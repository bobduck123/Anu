// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "falak"]
}

// ============================================================================
// MEMBERSHIP & SUBSCRIPTIONS
// ============================================================================

model MembershipPlan {
  id                 String         @id @default(cuid())
  name               String         @unique        // "Seed" | "Sapling" | "Forest"
  stripePriceId      String         @unique
  stripeProductId    String
  amountCents        Int            // Price in cents
  intervalMonths     Int            @default(1)
  creditGrantMonthly Int            // Monthly credit grant
  poolAllocationPct  Decimal        @db.Decimal(5,4)   // e.g. 0.2000 = 20%
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions      Subscription[]

  @@map("MembershipPlans")
  @@schema("public")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  incomplete
  incomplete_expired
  unpaid

  @@schema("public")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique // Flask User.id as string
  username             String
  planId               String
  plan                 MembershipPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  stripeCustomerId     String             @unique
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  streakMonths         Int                @default(0)
  lastPaymentAt        DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  creditTransactions   ImpactCreditTransaction[]
  revenueEvents        RevenueEvent[]

  @@index([stripeCustomerId])
  @@map("Subscriptions")
  @@schema("public")
}

// ============================================================================
// IMPACT POOLS & LEDGER (APPEND-ONLY)
// ============================================================================

model ImpactPool {
  id              String              @id @default(cuid())
  name            String
  description     String
  category        String
  targetAmountCents Int
  isActive        Boolean             @default(true)
  createdBy       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  ledgerEntries   ImpactLedgerEntry[]

  @@map("ImpactPools")
  @@schema("public")
}

enum LedgerEntryType {
  subscription_credit   // Monthly subscription allocation
  manual_credit         // Organizer manual credit
  allocation_debit      // Allocation to beneficiary (Phase 2)
  reversal              // Reversal of previous entry

  @@schema("public")
}

// APPEND-ONLY: enforced via PostgreSQL RULE + Prisma middleware
model ImpactLedgerEntry {
  id            String          @id @default(cuid())
  poolId        String
  pool          ImpactPool      @relation(fields: [poolId], references: [id], onDelete: Cascade)
  entryType     LedgerEntryType
  amountCents   Int             // positive = credit, negative = debit
  description   String
  referenceId   String?         // e.g. subscription ID, invoice ID
  referenceType String?         // e.g. "subscription", "invoice"
  reversalOf    String?         // ID of original entry if this is a reversal
  createdAt     DateTime        @default(now())
  createdBy     String

  @@index([poolId])
  @@index([createdAt])
  @@map("ImpactLedgerEntries")
  @@schema("public")
}

// ============================================================================
// IMPACT CREDITS (APPEND-ONLY)
// ============================================================================

enum CreditTxType {
  monthly_grant    // Monthly subscription grant
  streak_bonus     // Bonus for maintaining streak
  spend            // Spent on something
  adjustment       // Manual adjustment
  reversal         // Reversal of previous transaction

  @@schema("public")
}

// APPEND-ONLY: enforced via PostgreSQL RULE + Prisma middleware
model ImpactCreditTransaction {
  id              String        @id @default(cuid())
  userId          String
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  transactionType CreditTxType
  amountCredits   Int           // positive = earned, negative = spent
  description     String
  referenceId     String?       // e.g. invoice ID, pool ID
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ImpactCreditTransactions")
  @@schema("public")
}

// ============================================================================
// AUDIT LOG (APPEND-ONLY)
// ============================================================================

// APPEND-ONLY: enforced via PostgreSQL RULE + Prisma middleware
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String   // "participant" | "organizer"
  action     String   // e.g. "subscribe", "invoice_paid", "pool_credit"
  targetType String   // e.g. "subscription", "pool", "ledger_entry"
  targetId   String
  before     Json?    // Previous state (if applicable)
  after      Json?    // New state (if applicable)
  ip         String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("AuditLogs")
  @@schema("public")
}

// ============================================================================
// STRIPE WEBHOOKS (IDEMPOTENCY)
// ============================================================================

model StripeEvent {
  id           String   @id    // evt_xxx from Stripe
  type         String         // e.g. "invoice.paid", "checkout.session.completed"
  processedAt  DateTime @default(now())
  status       String         // "processed" | "failed" | "skipped"
  errorMessage String?
  payload      Json?          // Store original event payload for debugging

  @@index([processedAt])
  @@map("StripeEvents")
  @@schema("public")
}

// ============================================================================
// FLORA FAUNA MEMETIC MUTUAL-AID SUBSYSTEM
// ============================================================================

enum MemeLineageRelationType {
  remix
  reference
  response
  seed

  @@schema("public")
}

model CreatorChannel {
  id                       String                    @id @default(cuid())
  slug                     String                    @unique
  creatorUserId            String
  title                    String
  description              String?
  manifesto                String?
  sharePolicy              String                    @default("free_shareable")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  memes                    Meme[]
  nutrientSnapshots        NutrientSnapshot[]
  geologicalFormSnapshots  GeologicalFormSnapshot[]
  revenueEvents            RevenueEvent[]
  moderationCases          ModerationCase[]
  riskFlags                RiskFlag[]

  @@index([creatorUserId])
  @@map("creator_channels")
  @@schema("public")
}

model Meme {
  id                String                 @id @default(cuid())
  channelId         String
  channel           CreatorChannel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  slug              String                 @unique
  title             String
  body              String?
  summary           String?
  mediaUrl          String?
  attentionScore    Decimal                @default(0) @db.Decimal(10,4)
  shareable         Boolean                @default(true)
  createdBy         String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  parentEdges       MemeLineageEdge[]      @relation("LineageChild")
  childEdges        MemeLineageEdge[]      @relation("LineageParent")
  nutrientSnapshots NutrientSnapshot[]
  revenueEvents     RevenueEvent[]
  moderationCases   ModerationCase[]
  riskFlags         RiskFlag[]

  @@index([channelId, createdAt])
  @@index([createdBy, createdAt])
  @@map("memes")
  @@schema("public")
}

model MemeLineageEdge {
  id             String                  @id @default(cuid())
  parentMemeId   String
  childMemeId    String
  relationType   MemeLineageRelationType
  createdBy      String
  createdAt      DateTime                @default(now())
  parentMeme     Meme                    @relation("LineageParent", fields: [parentMemeId], references: [id], onDelete: Cascade)
  childMeme      Meme                    @relation("LineageChild", fields: [childMemeId], references: [id], onDelete: Cascade)

  @@unique([parentMemeId, childMemeId, relationType])
  @@index([childMemeId])
  @@map("meme_lineage_edges")
  @@schema("public")
}

model NutrientSnapshot {
  id                   String                   @id @default(cuid())
  channelId            String
  memeId               String?
  capturedAt           DateTime                 @default(now())
  careIndex            Decimal                  @db.Decimal(5,4)
  reciprocityIndex     Decimal                  @db.Decimal(5,4)
  resonanceIndex       Decimal                  @db.Decimal(5,4)
  originalityIndex     Decimal                  @db.Decimal(5,4)
  stewardshipIndex     Decimal                  @db.Decimal(5,4)
  mycelialDensityIndex Decimal                  @db.Decimal(5,4)
  ecologyIdentity      String
  identityConfidence   Decimal                  @db.Decimal(5,4)
  nutrientVector       Json
  capturedBy           String
  createdAt            DateTime                 @default(now())
  channel              CreatorChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  meme                 Meme?                    @relation(fields: [memeId], references: [id], onDelete: SetNull)
  geologicalForm       GeologicalFormSnapshot?

  @@index([channelId, capturedAt])
  @@index([memeId])
  @@map("nutrient_snapshots")
  @@schema("public")
}

model GeologicalFormSnapshot {
  id                    String           @id @default(cuid())
  channelId             String
  nutrientSnapshotId    String           @unique
  formKey               String
  strataSummary         String
  permeabilityIndex     Decimal          @db.Decimal(5,4)
  volatilityIndex       Decimal          @db.Decimal(5,4)
  stabilityIndex        Decimal          @db.Decimal(5,4)
  rationale             Json
  createdAt             DateTime         @default(now())
  channel               CreatorChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  nutrientSnapshot      NutrientSnapshot @relation(fields: [nutrientSnapshotId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@map("geological_form_snapshots")
  @@schema("public")
}

enum RevenueSourceType {
  subscription
  attention_sponsorship
  partnership
  grant
  other_downstream

  @@schema("public")
}

enum AttributionRecipientType {
  creator
  platform
  pool

  @@schema("public")
}

model RevenueEvent {
  id               String                    @id @default(cuid())
  subscriptionId   String?
  channelId        String?
  memeId           String?
  sourceType       RevenueSourceType
  grossAmountCents Int
  netAmountCents   Int
  currency         String                    @default("usd")
  memo             String?
  recognizedAt     DateTime                  @default(now())
  createdBy        String
  createdAt        DateTime                  @default(now())
  subscription     Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  channel          CreatorChannel?           @relation(fields: [channelId], references: [id], onDelete: SetNull)
  meme             Meme?                     @relation(fields: [memeId], references: [id], onDelete: SetNull)
  attributionSplits AttributionSplit[]

  @@index([subscriptionId, recognizedAt])
  @@index([channelId, recognizedAt])
  @@map("revenue_events")
  @@schema("public")
}

model AttributionSplit {
  id               String                    @id @default(cuid())
  revenueEventId   String
  recipientType    AttributionRecipientType
  recipientId      String
  sharePct         Decimal                   @db.Decimal(5,4)
  amountCents      Int
  metadata         Json?
  createdAt        DateTime                  @default(now())
  revenueEvent     RevenueEvent              @relation(fields: [revenueEventId], references: [id], onDelete: Cascade)

  @@index([revenueEventId])
  @@index([recipientType, recipientId])
  @@map("attribution_splits")
  @@schema("public")
}

enum LedgerAccountType {
  treasury
  allocation_reserve
  revenue_clearing
  creator_reserve
  mutual_aid_disbursed
  platform_reserve

  @@schema("public")
}

enum PoolLedgerEntryKind {
  funding_inflow
  allocation_reservation
  allocation_release
  creator_allocation
  pool_allocation
  disbursement
  adjustment

  @@schema("public")
}

model LiquidityPool {
  id                  String               @id @default(cuid())
  slug                String               @unique
  name                String
  description         String?
  policyJson          Json?
  isActive            Boolean              @default(true)
  createdBy           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ledgerAccounts      LedgerAccount[]
  ledgerEntries       LedgerEntry[]
  allocationRequests  AllocationRequest[]
  disbursements       Disbursement[]

  @@map("liquidity_pools")
  @@schema("public")
}

model LedgerAccount {
  id             String             @id @default(cuid())
  poolId         String
  code           String
  name           String
  accountType    LedgerAccountType
  currency       String             @default("usd")
  isSystem       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  pool           LiquidityPool      @relation(fields: [poolId], references: [id], onDelete: Cascade)
  entries        LedgerEntry[]

  @@unique([poolId, code])
  @@index([poolId, accountType])
  @@map("ledger_accounts")
  @@schema("public")
}

model LedgerEntry {
  id               String              @id @default(cuid())
  journalId        String
  poolId           String
  accountId        String
  entryKind        PoolLedgerEntryKind
  amountCents      Int
  referenceType    String?
  referenceId      String?
  memo             String
  createdBy        String
  createdAt        DateTime            @default(now())
  pool             LiquidityPool       @relation(fields: [poolId], references: [id], onDelete: Cascade)
  account          LedgerAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([poolId, createdAt])
  @@index([journalId])
  @@index([accountId, createdAt])
  @@map("ledger_entries")
  @@schema("public")
}

enum AllocationRequestStatus {
  pending
  approved
  rejected
  disbursed
  canceled

  @@schema("public")
}

model AllocationRequest {
  id             String                  @id @default(cuid())
  poolId         String
  requestedBy    String
  beneficiaryId  String
  purpose        String
  amountCents    Int
  status         AllocationRequestStatus @default(pending)
  rationale      String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  pool           LiquidityPool           @relation(fields: [poolId], references: [id], onDelete: Cascade)
  disbursements  Disbursement[]

  @@index([poolId, status, createdAt])
  @@index([beneficiaryId, createdAt])
  @@map("allocation_requests")
  @@schema("public")
}

enum DisbursementStatus {
  pending
  sent
  settled
  failed
  reversed

  @@schema("public")
}

model Disbursement {
  id                  String              @id @default(cuid())
  allocationRequestId String
  poolId              String
  amountCents         Int
  status              DisbursementStatus  @default(pending)
  destinationRef      String?
  executedBy          String?
  executedAt          DateTime?
  createdAt           DateTime            @default(now())
  allocationRequest   AllocationRequest   @relation(fields: [allocationRequestId], references: [id], onDelete: Cascade)
  pool                LiquidityPool       @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, status, createdAt])
  @@map("disbursements")
  @@schema("public")
}

enum ModerationSeverity {
  low
  medium
  high
  critical

  @@schema("public")
}

enum ModerationCaseStatus {
  open
  reviewed
  actioned
  closed

  @@schema("public")
}

enum ModerationActionType {
  note
  warn
  label
  limit
  remove
  restore
  close
  escalate

  @@schema("public")
}

model ModerationCase {
  id           String                @id @default(cuid())
  channelId    String?
  memeId       String?
  openedBy     String
  status       ModerationCaseStatus  @default(open)
  severity     ModerationSeverity
  summary      String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  channel      CreatorChannel?       @relation(fields: [channelId], references: [id], onDelete: SetNull)
  meme         Meme?                 @relation(fields: [memeId], references: [id], onDelete: SetNull)
  actions      ModerationAction[]
  riskFlags    RiskFlag[]

  @@index([status, createdAt])
  @@index([channelId])
  @@index([memeId])
  @@map("moderation_cases")
  @@schema("public")
}

model ModerationAction {
  id         String                @id @default(cuid())
  caseId      String
  actionType  ModerationActionType
  actorId     String
  notes       String?
  createdAt   DateTime             @default(now())
  moderationCase ModerationCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("moderation_actions")
  @@schema("public")
}

model RiskFlag {
  id          String              @id @default(cuid())
  channelId   String?
  memeId      String?
  caseId      String?
  flagType    String
  severity    ModerationSeverity
  reason      String
  status      String              @default("open")
  createdBy   String
  createdAt   DateTime            @default(now())
  channel     CreatorChannel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)
  meme        Meme?               @relation(fields: [memeId], references: [id], onDelete: SetNull)
  moderationCase ModerationCase?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([severity, createdAt])
  @@index([channelId])
  @@index([memeId])
  @@map("risk_flags")
  @@schema("public")
}

model DomainEvent {
  id             String    @id @default(cuid())
  aggregateType  String
  aggregateId    String
  eventType      String
  payload        Json
  actorId        String?
  correlationId  String?
  occurredAt     DateTime  @default(now())

  @@index([aggregateType, aggregateId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("domain_events")
  @@schema("public")
}

model AuditEvent {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  before     Json?
  after      Json?
  ip         String?
  requestId  String?
  occurredAt DateTime @default(now())

  @@index([entityType, entityId, occurredAt])
  @@index([actorId, occurredAt])
  @@map("audit_events")
  @@schema("public")
}

// ============================================================================
// FALAK PROTOCOL
// ============================================================================

enum FalakNodeStatus {
  draft
  active
  archived
  deleted

  @@map("falak_node_status")
  @@schema("falak")
}

enum FalakVisibility {
  public
  tenant
  restricted

  @@map("falak_visibility")
  @@schema("falak")
}

enum FalakEdgeStatus {
  active
  deprecated

  @@map("falak_edge_status")
  @@schema("falak")
}

enum FalakPolicyEffect {
  allow
  deny
  requires_approval

  @@map("falak_policy_effect")
  @@schema("falak")
}

enum FalakEventPolicyResult {
  allowed
  denied
  pending

  @@map("falak_event_policy_result")
  @@schema("falak")
}

enum FalakApprovalStatus {
  pending
  approved
  rejected
  cancelled

  @@map("falak_approval_status")
  @@schema("falak")
}

enum FalakLedgerCategory {
  financial
  governance
  verification
  moderation
  security
  publication

  @@map("falak_ledger_category")
  @@schema("falak")
}

model FalakTenant {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String             @unique
  name             String
  status           String             @default("active")
  settings         Json               @default("{}")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  actors           FalakActor[]
  actorRoles       FalakActorRole[]
  nodes            FalakNode[]
  edges            FalakEdge[]
  policies         FalakPolicy[]
  approvals        FalakApproval[]
  contributions    FalakContribution[]
  events           FalakEvent[]
  ledgerEntries    FalakLedgerEntry[]
  allocationProposals FalakAllocationProposal[]
  subscriptions    FalakSubscription[]
  derivedViews     FalakDerivedView[]
  auditLogEntries  FalakAuditLog[]
  mapDefinitions   FalakMapDefinition[]
  mapJobs          FalakMapJob[]

  @@map("tenants")
  @@schema("falak")
}

model FalakActor {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String            @map("tenant_id") @db.Uuid
  actorType            String            @map("actor_type")
  externalAuthId       String?           @map("external_auth_id")
  email                String?
  displayName          String?           @map("display_name")
  metadata             Json              @default("{}")
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenant               FalakTenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles                FalakActorRole[]
  createdNodes         FalakNode[]       @relation("FalakNodeCreatedBy")
  updatedNodes         FalakNode[]       @relation("FalakNodeUpdatedBy")
  createdEdges         FalakEdge[]       @relation("FalakEdgeCreatedBy")
  createdPolicies      FalakPolicy[]     @relation("FalakPolicyCreatedBy")
  updatedPolicies      FalakPolicy[]     @relation("FalakPolicyUpdatedBy")
  requestedApprovals   FalakApproval[]   @relation("FalakApprovalRequestedBy")
  resolvedApprovals    FalakApproval[]   @relation("FalakApprovalResolvedBy")
  approvalVotes        FalakApprovalVote[]
  contributions        FalakContribution[] @relation("FalakContributionActor")
  requestedAllocationProposals FalakAllocationProposal[] @relation("FalakAllocationProposalRequestedBy")
  events               FalakEvent[]
  auditLogEntries      FalakAuditLog[]

  @@unique([tenantId, externalAuthId])
  @@index([tenantId])
  @@map("actors")
  @@schema("falak")
}

model FalakActorRole {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  actorId      String      @map("actor_id") @db.Uuid
  roleName     String      @map("role_name")
  regionNodeId String?     @map("region_node_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant       FalakTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor        FalakActor  @relation(fields: [actorId], references: [id], onDelete: Cascade)
  regionNode   FalakNode?  @relation("FalakActorRoleRegion", fields: [regionNodeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, actorId, roleName, regionNodeId])
  @@index([actorId])
  @@index([tenantId, actorId])
  @@map("actor_roles")
  @@schema("falak")
}

model FalakNode {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  type             String
  status           FalakNodeStatus  @default(draft)
  visibility       FalakVisibility  @default(tenant)
  sensitivityClass String           @map("sensitivity_class") @default("normal")
  slug             String?
  title            String?
  summary          String?
  metadata         Json             @default("{}")
  // PostGIS geometry is represented in the database, but Prisma cannot project it
  // into typed client fields. Geometry reads/writes stay in repository raw SQL.
  geometry         Unsupported("geometry(Geometry,4326)")? @map("geometry")
  timeStart        DateTime?        @map("time_start") @db.Timestamptz(6)
  timeEnd          DateTime?        @map("time_end") @db.Timestamptz(6)
  createdById      String?          @map("created_by") @db.Uuid
  updatedById      String?          @map("updated_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  version          BigInt           @default(1)
  tenant           FalakTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy        FalakActor?      @relation("FalakNodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        FalakActor?      @relation("FalakNodeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  outgoingEdges    FalakEdge[]      @relation("FalakEdgeFrom")
  incomingEdges    FalakEdge[]      @relation("FalakEdgeTo")
  contributionNode FalakContribution? @relation("FalakContributionNode")
  contributionEvents FalakContribution[] @relation("FalakContributionEvent")
  contributionPools FalakContribution[] @relation("FalakContributionPool")
  allocationProposalNode FalakAllocationProposal? @relation("FalakAllocationProposalNode")
  allocationProposalEvents FalakAllocationProposal[] @relation("FalakAllocationProposalEvent")
  allocationProposalPools FalakAllocationProposal[] @relation("FalakAllocationProposalPool")
  allocationProposalTargets FalakAllocationProposal[] @relation("FalakAllocationProposalTarget")
  regionalAssignments FalakActorRole[] @relation("FalakActorRoleRegion")

  @@unique([tenantId, slug])
