# Apply these in the Vercel project for `frontend-next`.
# Use the same values in Preview and Production unless you have separate environments.

# Server-only rewrite targets
CORE_API_ORIGIN=https://anu-back-end.vercel.app
IMPACT_API_ORIGIN=https://anu-impact-service.vercel.app
MEMETICS_API_ORIGIN=https://anu-impact-service.vercel.app

# Public frontend runtime
NEXT_PUBLIC_SITE_URL=https://maanara.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=TODO_SET_WHEN_STRIPE_EXISTS
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=true
NEXT_PUBLIC_DEFAULT_NODE=au-nsw-sydney
NEXT_PUBLIC_FALAK_TENANT_ID=TODO_REQUIRED_FALAK_TENANT_ID

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
