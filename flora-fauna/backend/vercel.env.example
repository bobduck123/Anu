# Apply these in the Vercel project for `flora-fauna/backend`.
# Use explicit values for Preview and Production.
# In beta, keep the TODO database/Stripe values and set BETA_ALLOW_PLACEHOLDER_INFRA=true so the app boots in limited mode.
# For Supabase on Vercel, prefer the Supavisor transaction pooler connection string (`...pooler.supabase.com:6543`).
# Use `/healthz` for liveness probes and `/readiness` for DB-backed readiness checks.

VERCEL=1
FLASK_ENV=production
DEBUG=false
FORCE_HTTPS=true
BETA_ALLOW_PLACEHOLDER_INFRA=true
AUTO_CREATE_ALL=false

SECRET_KEY=replace-with-32-plus-char-secret
JWT_SECRET_KEY=replace-with-32-plus-char-secret
PUBLIC_JWT_SECRET_KEY=replace-with-32-plus-char-secret
CONTROL_JWT_SECRET_KEY=replace-with-32-plus-char-secret
CONTROL_PLANE_SHARED_SECRET=replace-with-16-plus-char-secret
# CONTROL_PLANE_SECRET_HEADER is a legacy alias only; prefer CONTROL_PLANE_SHARED_SECRET.
CONTROL_PLANE_SECRET_HEADER=
ENCRYPTION_MASTER_KEY=replace-with-32-plus-char-secret

DATABASE_URL=TODO_REQUIRED_POSTGRES_DATABASE_URL
CORS_ORIGINS=https://maanara.vercel.app,https://mudyin.vercel.app,https://mudyin-live.vercel.app,https://www.mudyin.com
FRONTEND_BASE_URL=https://maanara.vercel.app
# Backend control routes see the backend Host header for direct calls.
CONTROL_PLANE_HOSTS=anu-back-end.vercel.app
PUBLIC_PLATFORM_HOSTS=maanara.vercel.app,anu-back-end.vercel.app

STRIPE_SECRET_KEY=TODO_REQUIRED_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=TODO_REQUIRED_STRIPE_WEBHOOK_SECRET
STRIPE_PUBLISHABLE_KEY=TODO_REQUIRED_STRIPE_PUBLISHABLE_KEY

MAIL_SENDER_NAME=Manara Commons
PUBLIC_JWT_AUDIENCE=public
CONTROL_PLANE_JWT_AUDIENCE=control
CONTROL_PLANE_ALLOWED_ROLES=admin,institution,publisher,platform_admin,node_admin,board_member,treasury_guardian
CONTROL_ACCESS_TOKEN_EXPIRES_MINUTES=15
CONTROL_CONNECTOR_PULL_ASYNC_DEFAULT=false
CONTROL_REQUIRE_TOKEN_USE_CLAIM=true
CONTROL_REQUIRE_TOKEN_GRANT=true
CONNECTOR_PULL_JOB_LEASE_SECONDS=180
CONNECTOR_PULL_JOB_STALE_SECONDS=900
