# =============================================================================
# Flora Fauna Backend - Git Ignore
# =============================================================================

# Environment files (CRITICAL - contains secrets)
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Database
*.db
*.sqlite
*.sqlite3
instance/

# Logs
*.log
logs/

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Secrets (additional safety)
secrets/
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Temporary files
tmp/
temp/
*.tmp
