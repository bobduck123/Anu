# =============================================================================
# Flora-Fauna Civic Commons - Environment Configuration Template
# =============================================================================
# 
# SECURITY WARNING: Never commit actual secrets to version control.
# Copy this file to .env and fill in your actual values.
#
# Generate secure secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# This service connects to schema 001_core_schema (node, user, event, etc)
# For multi-tenant support, also connects to falak schema (001_falak_schema)
#
# =============================================================================

# =============================================================================
# CRITICAL: Core Secrets (REQUIRED)
# =============================================================================
# These MUST be set and must be >= 32 characters
# Use cryptographically secure random values

SECRET_KEY=your-secret-key-here-min-32-chars-required
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars-required-and-different

# Split JWT signing keys (required in production)
PUBLIC_JWT_SECRET_KEY=your-public-jwt-signing-secret-min-32-chars
CONTROL_JWT_SECRET_KEY=your-control-jwt-signing-secret-min-32-chars

# =============================================================================
# Database (REQUIRED in production)
# Connected to Supabase with access to PUBLIC schema for Flora-Fauna models
# Connects to: 001_core_schema tables (node, user, event, venue, microcosm, etc.)
# =============================================================================
# Development: sqlite:///site.db
# Production: Use one of the following (in priority order):
#   - DATABASE_URL (custom)
#   - POSTGRES_URL (Supabase/Vercel auto-provisioned)
#   - POSTGRES_PRISMA_URL (Supabase/Vercel auto-provisioned)

DATABASE_URL=sqlite:///site.db

# For Supabase/Vercel deployment, these are auto-provisioned:
# POSTGRES_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# POSTGRES_PRISMA_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# POSTGRES_URL_NON_POOLING=postgresql://postgres.xxx:password@aws-0-region.supabase.com:5432/postgres

# Connection Pool Settings (PostgreSQL) - ignored on Vercel serverless
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =============================================================================
# Environment Configuration
# =============================================================================
# FLASK_ENV: development | production | testing
FLASK_ENV=development

# Optional aliases used by deployment platforms:
# APP_ENV / ENVIRONMENT: development | production | testing
APP_ENV=
ENVIRONMENT=

# DEBUG: Set to 'true' ONLY in development
DEBUG=false

# Enforce that SECRET_KEY/JWT_SECRET_KEY must be explicitly provided
# even when FLASK_ENV is not production (recommended for staging/preview).
REQUIRE_STRICT_SECRETS=false

# =============================================================================
# Security Settings
# =============================================================================
# Force HTTPS redirect
FORCE_HTTPS=false

# CORS Origins (comma-separated, no spaces)
# Development: http://localhost:3000,http://localhost:3001
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Encryption key for sensitive data (optional but recommended)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=

# =============================================================================
# Rate Limiting
# =============================================================================
# Memory backend for single instance
RATELIMIT_STORAGE_URI=memory://

# Redis backend for distributed setup (production)
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# =============================================================================
# Stripe Payment Processing (REQUIRED for payment features)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# Email Configuration (REQUIRED for notifications)
# =============================================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_SENDER_NAME=Manara Commons

# Public frontend URL used for checkout return links and creator surfaces.
FRONTEND_BASE_URL=http://localhost:3000

# =============================================================================
# Sentry Error Tracking (Optional but recommended for production)
# =============================================================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Alpha/Feature Flags (Development only)
# =============================================================================
ALPHA_PUBLIC=true
ALPHA_SEED=true
ALPHA_AUTH_OPTIONAL=true
ALPHA_DEFAULT_USERNAME=alpha_public

# =============================================================================
# Data Retention & Privacy
# =============================================================================
DATA_RETENTION_DAYS_EVIDENCE=365
DP_EPSILON=1.0
DP_MIN_COHORT=30

# =============================================================================
# File Upload Configuration
# =============================================================================
# Max file size (5MB default, cannot exceed in production)
MAX_CONTENT_LENGTH=5242880

# Optional writable roots. On Vercel, the app automatically remaps relative
# write paths into /tmp/manara unless you override these explicitly.
UPLOAD_FOLDER=static/uploads

# =============================================================================
# Cultural Intelligence Architecture (Public vs Control Plane)
# =============================================================================
# Public token audience used for normal user/app APIs.
PUBLIC_JWT_AUDIENCE=public

# Control token audience required by /api/control/* endpoints.
CONTROL_PLANE_JWT_AUDIENCE=control

# Control token TTL in minutes (short-lived privileged tokens).
CONTROL_ACCESS_TOKEN_EXPIRES_MINUTES=15

# If true, POST /api/control/connectors/{id}/pull queues async jobs by default.
CONTROL_CONNECTOR_PULL_ASYNC_DEFAULT=false

# Enforce token_use=control claim on /api/control/* requests.
CONTROL_REQUIRE_TOKEN_USE_CLAIM=true

# Require a live control token grant record (jti allowlist + revocation check).
CONTROL_REQUIRE_TOKEN_GRANT=true

# Optional JSON override of control scopes per role.
# Example:
# CONTROL_ROLE_SCOPES_JSON={"platform_admin":["control:*"],"publisher":["worlds:publish","worlds:patch","worlds:keys:read"]}
CONTROL_ROLE_SCOPES_JSON=

# Restrict control plane APIs to dedicated hostnames.
# In production set to control host(s), e.g. control.api.example.com
# Required for non-development runtimes (production/preview/staging).
CONTROL_PLANE_HOSTS=localhost,127.0.0.1

# Roles allowed to access control plane APIs (comma-separated).
CONTROL_PLANE_ALLOWED_ROLES=admin,institution,publisher,platform_admin,node_admin,board_member,treasury_guardian

# Control-plane gateway secret (required for non-development runtimes).
# Callers to /api/control/* must send header: X-Control-Plane-Secret
CONTROL_PLANE_SHARED_SECRET=

# World snapshot signing and storage settings.
WORLD_STORAGE_ROOT=static/worlds
WORLD_SIGNING_PRIVATE_KEY_FILE=
WORLD_SIGNING_PUBLIC_KEY_FILE=
WORLD_SIGNING_KEY_ID=dev-ed25519

# Connector worker lease and stale-recovery tuning.
CONNECTOR_PULL_JOB_LEASE_SECONDS=180
CONNECTOR_PULL_JOB_STALE_SECONDS=900

# Control-audit checkpoint export storage root.
AUDIT_CHECKPOINT_STORAGE_ROOT=static/audit_checkpoints
