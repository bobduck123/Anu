# Presence Gardens + Halls local contract environment.
# Copying is optional: backend/scripts/dev_presence_contract_bootstrap.py sets the
# same safe defaults unless these values are overridden in the shell.

FLASK_ENV=development
APP_ENV=development
AUTO_CREATE_ALL=true

# Default matches docker-compose.presence-contract.yml. The bootstrap script also
# falls back to an existing localhost:5433 Postgres if present.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/presence_contract_local

# Local-only contract secrets. Do not reuse in production.
SECRET_KEY=presence-contract-local-secret-key-0001
JWT_SECRET_KEY=presence-contract-local-jwt-secret-key-0001
PUBLIC_JWT_SECRET_KEY=presence-contract-local-public-jwt-secret-0001
CONTROL_JWT_SECRET_KEY=presence-contract-local-control-jwt-secret-0001

CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:3100,http://localhost:3100
CONTROL_PLANE_HOSTS=127.0.0.1,localhost,control.test
CONTROL_PLANE_SHARED_SECRET=presence-contract-local-control-secret
CONTROL_PLANE_ALLOWED_ROLES=platform_admin,node_admin
CONTROL_PLANE_JWT_AUDIENCE=control
CONTROL_REQUIRE_TOKEN_GRANT=false

RATELIMIT_STORAGE_URI=memory://
PRESENCE_CONTRACT_BACKEND_URL=http://127.0.0.1:5106
